# Fleet Management System v3.0 - Environment Configuration
# Copy this to .env and update with your values

# Application
NODE_ENV=production
PORT=3000

# Security - API Keys (Generate strong random keys)
# Use: openssl rand -hex 32
VALID_API_KEYS=your-super-secret-api-key-here,another-api-key-if-needed

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_BLOCK_DURATION=900000

# DDoS Protection
DDOS_BURST_LIMIT=20
DDOS_BURST_WINDOW_MS=1000
DDOS_AUTO_BLOCK_THRESHOLD=3

# Monitoring & Alerts
SECURITY_ALERT_EMAIL=security@valtara.ai
ENABLE_MONITORING=true

# Database (if applicable)
# DATABASE_URL=postgresql://user:password@localhost:5432/fleet_db

# JWT Secret (if using authentication)
# JWT_SECRET=your-jwt-secret-key-here
# JWT_EXPIRES_IN=24h

# CORS Allowed Origins (comma-separated)
CORS_ALLOWED_ORIGINS=https://fleet.valtara.ai,https://valtara.ai

# Session Secret (if using sessions)
# SESSION_SECRET=your-session-secret-here

# Email Configuration (for alerts)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Log Level
LOG_LEVEL=info

# Maximum request body size (in bytes)
MAX_REQUEST_SIZE=1048576

# Request timeout (in milliseconds)
REQUEST_TIMEOUT=30000

# Enable/Disable Features
ENABLE_RATE_LIMITING=true
ENABLE_IP_BLOCKING=true
ENABLE_REQUEST_VALIDATION=true
ENABLE_SECURITY_HEADERS=true

# Cloudflare (if using)
# CLOUDFLARE_API_KEY=
# CLOUDFLARE_EMAIL=

# Backup
# BACKUP_ENABLED=true
# BACKUP_SCHEDULE=0 2 * * *
